{
  "name": "ressa-noise-detector-app",
  "version": "0.1.0",
  "description": "Local-only desktop noise monitor with Ressa face reactions",
  "main": "dist-electron/main.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --port 5173 --strictPort\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on dist-electron/main.js tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 node scripts/start-electron.cjs\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "generate:icons": "node scripts/generate-icons.cjs",
    "lint": "eslint .",
    "package": "npm run generate:icons && npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.ressa.noisedetector",
    "productName": "Ressa Noise Detector App",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": "nsis"
    },
    "directories": {
      "buildResources": "build"
    }
  }
}
